# =============================================================================
# INTRASIAP BILLING AUTOMATION — Variables de entorno
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo y renómbralo a ".env"
#   2. Llena los valores de cada variable
#   3. NUNCA subas el archivo .env a git
# =============================================================================

# ─── INGRAM MICRO (OAuth 2.0) ─────────────────────────────────────────────────
# Obtener en: developer.ingrammicro.com
INGRAM_CLIENT_ID=
INGRAM_CLIENT_SECRET=
INGRAM_CUSTOMER_NUMBER=
INGRAM_SENDER_ID=
INGRAM_COUNTRY_CODE=MX
# Cambiar a "false" cuando pases a producción
INGRAM_SANDBOX=true

# ─── SYSCOM (OAuth 2.0) ───────────────────────────────────────────────────────
# Obtener en: developers.syscom.mx → "Mis aplicaciones"
SYSCOM_CLIENT_ID=
SYSCOM_CLIENT_SECRET=

# ─── CT INTERNACIONAL (JWT Token) ────────────────────────────────────────────
# Proporcionado por tu representante comercial de CT
CT_TOKEN=
CT_ATTRIBUTE_1=
CT_ATTRIBUTE_2=
CT_ATTRIBUTE_3=

# ─── CVA — GRUPO CVA (SOAP) ───────────────────────────────────────────────────
# Credenciales de acceso al web service CVA
CVA_USUARIO=
CVA_PASSWORD=

# ─── INTCOMEX (API Key) ───────────────────────────────────────────────────────
# Obtener en: iws.intcomex.com → sección de credenciales
INTCOMEX_API_KEY=

# ─── PCH CONNECT (Personal ID + Headers) ─────────────────────────────────────
# Contacto para activar integración: technical@pchconnect.com
PCH_PERSONAL_ID=
PCH_HEADER_1=
PCH_HEADER_2=
PCH_HEADER_3=

# ─── EXEL DEL NORTE (REST — pendiente documentación) ─────────────────────────
# Solicitar credenciales y docs directamente a Exel del Norte
EXEL_API_KEY=
EXEL_API_URL=https://api01.exeldelnorte.com.mx/

# ─── EMAIL (para envío de cotizaciones) ──────────────────────────────────────
# Configurar la credencial de Gmail/Outlook en n8n y referenciar su nombre aquí
EMAIL_CREDENTIAL_NAME=Gmail - Intrasiap
EMAIL_FROM=cotizaciones@intrasiap.com
