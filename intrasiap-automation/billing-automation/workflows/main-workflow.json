    {
      "id": "f1a2b3c4-d5e6-7890-abcd-222222222222",
      "name": "Preparar Datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ],
      "parameters": {
        "jsCode": "const d = $input.first().json;\n\n// Mapeo de campos del form (posicional por orden de definición)\nconst fields = Object.values(d).filter(v => v !== undefined);\n\n// Extraer datos por nombre de campo\nconst vendedor = {\n  nombre:   d['Tu nombre completo'] || '',\n  puesto:   d['Tu puesto'] || '',\n  telefono: d['Tu teléfono'] || '',\n  email:    d['Tu correo (recibirás la cotización aquí)'] || ''\n};\n\nconst cliente = {\n  nombre:  d['Nombre del cliente'] || '',\n  puesto:  d['Puesto del cliente'] || '',\n  empresa: d['Empresa / Cuenta'] || ''\n};\n\n// Construir productos (hasta 3)\nconst buildQuery = (marca, desc, ram, storage, color, mem, garantia) => {\n  const parts = [marca, desc, ram, storage, color, mem, garantia]\n    .filter(Boolean).join(' ');\n  return parts.trim();\n};\n\nconst productos = [];\n\n// Producto 1 (siempre presente)\nconst p1 = {\n  searchQuery: buildQuery(\n    d['Marca'],\n    d['Descripción / Modelo'],\n    d['RAM (ej: 16GB)'],\n    d['Almacenamiento (ej: 512GB SSD)'],\n    d['Color'],\n    d['Tipo de Memoria (ej: DDR5)'],\n    d['Garantía']\n  ),\n  marca:    d['Marca'] || '',\n  cantidad: Number(d['Cantidad']) || 1\n};\nif (p1.searchQuery) productos.push(p1);\n\n// Producto 2 (opcional)\nconst p2Desc = d['Descripción / Modelo_1'] || d['Descripción / Modelo (2)'] || '';\nif (p2Desc || d['Marca_1']) {\n  productos.push({\n    searchQuery: buildQuery(\n      d['Marca_1'] || '', p2Desc,\n      d['RAM (ej: 32GB)'] || '', d['Almacenamiento (ej: 1TB NVMe)'] || '',\n      d['Color_1'] || '', d['Tipo de Memoria_1'] || '', d['Garantía_1'] || ''\n    ),\n    marca:    d['Marca_1'] || '',\n    cantidad: Number(d['Cantidad_1']) || 1\n  });\n}\n\n// Producto 3 (opcional)\nconst p3Desc = d['Descripción / Modelo_2'] || '';\nif (p3Desc || d['Marca_2']) {\n  productos.push({\n    searchQuery: buildQuery(\n      d['Marca_2'] || '', p3Desc,\n      d['RAM_2'] || '', d['Almacenamiento_2'] || '',\n      d['Color_2'] || '', d['Tipo de Memoria_2'] || '', d['Garantía_2'] || ''\n    ),\n    marca:    d['Marca_2'] || '',\n    cantidad: Number(d['Cantidad_2']) || 1\n  });\n}\n\nreturn [{ json: { vendedor, cliente, productos, fechaSolicitud: new Date().toISOString() } }];"
      }
    },
