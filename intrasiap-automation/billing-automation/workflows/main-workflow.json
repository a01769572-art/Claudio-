          "name": "Google Gemini — Intrasiap"
        }
      }
    },
    {
      "id": "f1a2b3c4-d5e6-7890-abcd-001100110011",
      "name": "Parsear y Generar Excel",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2060,
        400
      ],
      "parameters": {
        "jsCode": "// Parsear respuesta del agente Excel\nconst raw = $input.first().json.output || $input.first().json.text || '';\nlet excelData;\ntry {\n  const m = raw.match(/\\{[\\s\\S]*\\}/);\n  excelData = JSON.parse(m ? m[0] : raw);\n} catch(e) {\n  excelData = { celdas: {}, productos: [] };\n}\n\n// Recuperar HTML del benchmarking y metadata\nconst meta = $('Parsear Respuesta Benchmarking').first().json;\n\nreturn [{\n  json: {\n    excelData,\n    htmlReporte:    meta.htmlReporte || '',\n    vendedorEmail:  meta.vendedor?.email || '',\n    clienteNombre:  meta.cliente?.nombre || '',\n    fechaSolicitud: meta.fechaSolicitud || new Date().toISOString()\n  }\n}];"
      }
    },
    {
      "id": "f1a2b3c4-d5e6-7890-abcd-002200220022",
      "name": "Generar PDF Benchmarking",
      "type": "n8n-nodes-base.html",
      "typeVersion": 1,
      "position": [
        2280,
        300
      ],
      "parameters": {
        "operation": "generatePdf",
        "html": "={{ $json.htmlReporte }}",
        "options": {
          "format": "A4",
          "margin": {
            "top": "20mm",
            "bottom": "20mm",
            "left": "15mm",
            "right": "15mm"
          }
        },
        "binaryPropertyName": "benchmarkPdf"
      }
    },
    {
